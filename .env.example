# LoopHive — LLM Provider API Keys
# Copy this file to .env and fill in your API keys

# === Primary LLM Providers (Free Tiers) ===
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
# NVIDIA NIM (build.nvidia.com) — free Nemotron-70B + Qwen
NVIDIA_API_KEY=your_nvidia_api_key_here
# Optional: override model ids if NVIDIA renames them
# NVIDIA_NEMOTRON_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
# NVIDIA_QWEN_MODEL=qwen/qwen2.5-coder-32b-instruct
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OpenRouter free model ids change often — set this to a current ':free' model
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
CEREBRAS_API_KEY=your_cerebras_api_key_here
XAI_API_KEY=your_xai_api_key_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# === Research & Images ===
# Tavily (tavily.com) — deep web research for the research agent (free 1000/mo)
TAVILY_API_KEY=your_tavily_api_key_here
# Pexels (pexels.com/api) — royalty-free images for ebooks
PEXELS_API_KEY=your_pexels_api_key_here

# === Publishing Platforms ===
MEDIUM_API_TOKEN=your_medium_token
SUBSTACK_EMAIL=your_substack_email
SUBSTACK_PASSWORD=your_substack_password
GUMROAD_ACCESS_TOKEN=your_gumroad_token
PAYHIP_API_KEY=your_payhip_key
# Gumroad ping → records real sales into Earnings. Point Gumroad's ping URL at
# https://your-host/webhooks/gumroad ; optional shared secret:
GUMROAD_WEBHOOK_SECRET=

# Static blog site (real SEO hub) built from published articles
BUILD_SITE=true
SITE_NAME=AI Hub
SITE_DIR=site

# === Social Media ===
# Telegram Bot API (marketing auto-posting). From @BotFather + a channel the bot admins.
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=@yourchannel
TWITTER_API_KEY=your_twitter_key
TWITTER_API_SECRET=your_twitter_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_token
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# === Analytics ===
GOOGLE_ANALYTICS_PROPERTY_ID=your_ga_property_id

# === You, the Boss ===
BOSS_NAME=Your Name
BOSS_EMAIL=you@example.com    # agents escalate critical issues here (needs SMTP)

# === App Config ===
DATABASE_URL=sqlite+aiosqlite:///./loophive.db
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
LOG_LEVEL=INFO
MAX_DAILY_ARTICLES=5
MAX_DAILY_PRODUCTS=2
MAX_WEEKLY_PRODUCTS=1
QUALITY_THRESHOLD=70
PLAGIARISM_THRESHOLD=85

# === Niche & Pipeline ===
FORCED_NICHE=AI Tools, Agentic Workflows & Prompt Engineering
# TOPIC_POOL=topic one|topic two|topic three   (| separated; blank = built-in AI list)
SWARM_INTERVAL_SECONDS=3600
SWARM_IDLE_SECONDS=1800

# === Research / Fusion / Ebook ===
RESEARCH_ENABLED=true
RESEARCH_DEPTH=4
RESEARCH_MAX_SOURCES=8
FUSION_ENABLED=true
FUSION_PROPOSERS=3
FUSION_AGGREGATOR=nvidia-ultra
FINALIZE_ENABLED=true
FINALIZE_PROVIDER=nvidia-ultra
EBOOK_PDF_ENABLED=true
EBOOK_MIN_SECTIONS=12
EBOOK_SECTION_WORDS=900

# === Code Products (GitHub portfolio) ===
CODE_PRODUCTS_ENABLED=true
CODE_PRODUCT_EVERY=3
# Rotated each code build (| separated): tools, packs, extensions, websites
CODE_PRODUCT_TYPES=developer tool|github starter kit|browser extension|static website|python package
# GitHub: fine-grained PAT with Contents read/write (github.com/settings/tokens)
GITHUB_TOKEN=your_github_token_here
GITHUB_ORG=          # leave blank to publish under your own account

# === Outreach (off + dry-run by default; transparent, 1/day) ===
OUTREACH_ENABLED=false
OUTREACH_DRY_RUN=true
OUTREACH_PER_DAY=1
# SMTP for sending (used by outreach + email replies). The agent's "own email".
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# === Two-way Email (read inbox, understand, act, reply) ===
EMAIL_ENABLED=false        # read + process the inbox
EMAIL_AUTO_REPLY=false     # actually send replies (else drafted to /inbox); STOP always honored
EMAIL_MAX_PER_RUN=10
# IMAP for reading (defaults to the SMTP account above — same Gmail app password works)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
# IMAP_USER=            # blank = use SMTP_USER
# IMAP_PASSWORD=        # blank = use SMTP_PASSWORD
